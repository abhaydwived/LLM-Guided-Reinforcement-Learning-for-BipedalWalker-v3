# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Virtual environments
# Note: DO NOT ignore "env/" as it's the custom codebase directory in this project!
venv/
.venv/
env.bak/
venv.bak/

# Environment Variables
.env
.env.local

# Jupyter Notebook
.ipynb_checkpoints

# IDE / Editor configuration
.idea/
.vscode/
*.swp
*.swo
*~
.spyderproject
.spyproject

# OS level files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# RL / Machine Learning Specific Files
# Ignore PyTorch/SB3 models by default to avoid bloating git
# You can selectively force track definitive models with: `git add -f models/best_model.zip`
*.pt
*.pth
*.zip
*.pkl


# Custom Project ignores
# Uncomment below if you want to ignore the metrics history entirely:
# logs/metrics_history.json
# Uncomment below if you don't want to track archived reward iterations:
# rewards/archive/*.py